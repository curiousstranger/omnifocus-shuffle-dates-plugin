{
  "author": "George Mandis, Matt Cable",
  "targets": ["omnifocus"],
  "type": "bundle",
  "identifier": "org.curiousstranger.ShuffleDates",
  "name": "Shuffle Dates",
  "version": "0.5",
  "defaultLocale": "en",
  "description": "A plug-in bundle that randomly assigns due, defer, and review dates to selected tasks and projects with customizable options and quick presets",
  "label": "Shuffle Dates",
  "mediumLabel": "Shuffle Dates",
  "paletteLabel": "Shuffle Dates",
  "actions": [
    {
      "identifier": "customShuffle",
      "label": "Shuffle Dates (Custom)",
      "mediumLabel": "Custom Shuffle",
      "paletteLabel": "Custom",
      "image": "shuffle",
      "script": "customShuffle.js"
    },
    {
      "identifier": "dueDates7",
      "label": "Shuffle Due Dates Over 7 Days",
      "mediumLabel": "Due 7d",
      "paletteLabel": "Due 7d",
      "image": "calendar.badge.plus",
      "script": "dueDates7.js"
    },
    {
      "identifier": "dueDates14",
      "label": "Shuffle Due Dates Over 14 Days",
      "mediumLabel": "Due 14d",
      "paletteLabel": "Due 14d",
      "image": "calendar.badge.plus",
      "script": "dueDates14.js"
    },
    {
      "identifier": "dueDates30",
      "label": "Shuffle Due Dates Over 30 Days",
      "mediumLabel": "Due 30d",
      "paletteLabel": "Due 30d",
      "image": "calendar.badge.plus",
      "script": "dueDates30.js"
    },
    {
      "identifier": "deferDates7",
      "label": "Shuffle Defer Dates Over 7 Days",
      "mediumLabel": "Defer 7d",
      "paletteLabel": "Defer 7d",
      "image": "calendar.badge.clock",
      "script": "deferDates7.js"
    },
    {
      "identifier": "deferDates14",
      "label": "Shuffle Defer Dates Over 14 Days",
      "mediumLabel": "Defer 14d",
      "paletteLabel": "Defer 14d",
      "image": "calendar.badge.clock",
      "script": "deferDates14.js"
    },
    {
      "identifier": "deferDates30",
      "label": "Shuffle Defer Dates Over 30 Days",
      "mediumLabel": "Defer 30d",
      "paletteLabel": "Defer 30d",
      "image": "calendar.badge.clock",
      "script": "deferDates30.js"
    },
    {
      "identifier": "reviewDates7",
      "label": "Shuffle Review Dates Over 7 Days",
      "mediumLabel": "Review 7d",
      "paletteLabel": "Review 7d",
      "image": "calendar.badge.checkmark",
      "script": "reviewDates7.js"
    },
    {
      "identifier": "reviewDates14",
      "label": "Shuffle Review Dates Over 14 Days",
      "mediumLabel": "Review 14d",
      "paletteLabel": "Review 14d",
      "image": "calendar.badge.checkmark",
      "script": "reviewDates14.js"
    },
    {
      "identifier": "reviewDates30",
      "label": "Shuffle Review Dates Over 30 Days",
      "mediumLabel": "Review 30d",
      "paletteLabel": "Review 30d",
      "image": "calendar.badge.checkmark",
      "script": "reviewDates30.js"
    }
  ]
}