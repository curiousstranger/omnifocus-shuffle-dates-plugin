{
  "author": "George Mandis, Matt Cable",
  "targets": ["omnifocus"],
  "type": "bundle",
  "identifier": "org.curiousstranger.ShuffleDates",
  "version": "0.5",
  "label": "Shuffle Dates",
  "defaultLocale": "en",
  "description": "A plug-in bundle that randomly assigns due, defer, and review dates to selected tasks and projects with customizable options and quick presets",
  "libraries": [
    {
      "identifier": "shuffleDatesLibrary",
      "script": "shuffleDatesLibrary.js"
    }
  ],
  "actions": [
    {
      "identifier": "customShuffle",
      "image": "shuffle",
      "script": "customShuffle.js"
    },
    {
      "identifier": "dueDates7",
      "image": "calendar.badge.plus",
      "script": "dueDates7.js"
    },
    {
      "identifier": "dueDates14",
      "image": "calendar.badge.plus",
      "script": "dueDates14.js"
    },
    {
      "identifier": "dueDates30",
      "image": "calendar.badge.plus",
      "script": "dueDates30.js"
    },
    {
      "identifier": "deferDates7",
      "image": "calendar.badge.clock",
      "script": "deferDates7.js"
    },
    {
      "identifier": "deferDates14",
      "image": "calendar.badge.clock",
      "script": "deferDates14.js"
    },
    {
      "identifier": "deferDates30",
      "image": "calendar.badge.clock",
      "script": "deferDates30.js"
    },
    {
      "identifier": "reviewDates7",
      "image": "calendar.badge.checkmark",
      "script": "reviewDates7.js"
    },
    {
      "identifier": "reviewDates14",
      "image": "calendar.badge.checkmark",
      "script": "reviewDates14.js"
    },
    {
      "identifier": "reviewDates30",
      "image": "calendar.badge.checkmark",
      "script": "reviewDates30.js"
    }
  ]
}